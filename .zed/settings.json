{
  "format_on_save": "on",
  "formatter": "language_server",
  "languages": {
    "Rust": {
      "formatter": "language_server",
      "format_on_save": "on",
    },
    "TypeScript": {
      "format_on_save": "on",
      "code_actions_on_format": {
        "source.fixAll.eslint": true,
        "source.organizeImports": true,
      },
    },
    "TSX": {
      "format_on_save": "on",
      "code_actions_on_format": {
        "source.fixAll.eslint": true,
        "source.organizeImports": true,
      },
    },
    "JavaScript": {
      "format_on_save": "on",
      "code_actions_on_format": {
        "source.fixAll.eslint": true,
        "source.organizeImports": true,
      },
    },
  },
  "lsp": {
    "rust-analyzer": {
      "initialization_options": {
        "check": {
          "command": "clippy",
        },
        "cargo": {
          "allTargets": true,
          "allFeatures": true,
        },
      },
    },
  },
}
