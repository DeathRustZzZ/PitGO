    IdentityReservationProof["IdentityReservationProof - proof for contact mutation"]
    CustomerConsentLedger["CustomerConsentLedger - required legal consents"]
    CustomerActivationPolicy["CustomerActivationPolicy - activation eligibility"]
    ActivationPermit["ActivationPermit - short-lived activation contract"]
    CustomerActivationApplicationService["CustomerActivationApplicationService - orchestrates activation"]
    CustomerContactApplicationService["CustomerContactApplicationService - orchestrates contact changes"]
    UnitOfWork["UnitOfWork - transaction boundary and version checks"]
    EventEnvelopeFactory["EventEnvelopeFactory - wraps pending events"]
    EventStore["EventEnvelope - persisted audit event"]
    AccessContext["AccessContext - authorization before command"]
    ActionContext["ActionContext - immutable command audit context"]

