            -CustomerId customer_id
            -DateTime~Utc~ expires_at
            -new(reservation) IdentityReservationProof
            +reservation_id() IdentityReservationId
            +identity_key() IdentityKey
            +customer_id() CustomerId
            +expires_at() DateTime~Utc~
        }
    }

