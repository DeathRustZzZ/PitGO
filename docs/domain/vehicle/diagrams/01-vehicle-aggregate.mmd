%% Vehicle Aggregate Root — internal structure, commands, invariants, errors.
%% Source of truth: ARCHITECTURE.md § Vehicle Domain › Vehicle Aggregate
%% Mirrors: docs/domain/customer/diagrams/01-customer-lifecycle.mmd

classDiagram
    direction LR

    class Vehicle {
        <<AggregateRoot>>
        -VehicleId id
        -VehicleIdentity identity
        -VehicleSpecs specs
        -VehicleStatus status
        -Option~VerificationInfo~ verification
        -AggregateVersion version
        -DateTime~Utc~ created_at
        -Option~DateTime~Utc~~ updated_at
        -Vec~PendingVehicleEvent~ pending_events
        +create(id, specs, ctx, now) Result~Vehicle, VehicleError~
        +assign_vin(proof, vin, ctx, now) Result~ChangeOutcome, VehicleError~
        +correct_vin(proof, vin, reason, ctx, now) Result~ChangeOutcome, VehicleError~
        +change_license_plate(plate, ctx, now) Result~ChangeOutcome, VehicleError~
        +change_registration_document(doc, ctx, now) Result~ChangeOutcome, VehicleError~
        +link_external_reference(ref, ctx, now) Result~ChangeOutcome, VehicleError~
        +unlink_external_reference(provider, ext_id, ctx, now) Result~ChangeOutcome, VehicleError~
        +update_specs(specs, ctx, now) Result~ChangeOutcome, VehicleError~
        +verify(source, confidence, ext_ref, ctx, now) Result~ChangeOutcome, VehicleError~
        +activate(permit, ctx, now) Result~ChangeOutcome, VehicleError~
        +archive(ctx, now) Result~ChangeOutcome, VehicleError~
        +mark_disputed(reason, ctx, now) Result~ChangeOutcome, VehicleError~
        +resolve_dispute(resolution, ctx, now) Result~ChangeOutcome, VehicleError~
        +delete(ctx, now) Result~ChangeOutcome, VehicleError~
        +pull_pending_events() Vec~PendingVehicleEvent~
    }

    class VehicleId {
        <<ValueObject>>
        <<TypeSafeNewtype>>
        -Uuid value
        +new() VehicleId
        +from_uuid(Uuid) VehicleId
        +as_uuid() Uuid
    }

    class VehicleStatus {
        <<StateMachine>>
        Draft
        Active
        Archived
        Disputed
        Deleted
    }

    class VehicleIdentity {
        <<ValueObject>>
        -Option~Vin~ vin
        -Option~LicensePlate~ license_plate
        -Option~RegistrationDocument~ registration_document
        -Vec~ExternalVehicleReference~ external_refs
        +has_reliable_identity() bool
    }

    class Vin {
        <<ValueObject>>
        -String value
        +parse(raw: String) Result~Vin, VehicleError~
        +as_str() str
    }

    class LicensePlate {
        <<ValueObject>>
        -String value
        -CountryCode country_code
        -Option~RegionCode~ region
    }

    class RegistrationDocument {
        <<ValueObject>>
        -Option~DocumentNumber~ number
        -CountryCode country_code
        -Option~DateTime~Utc~~ issued_at
    }

    class ExternalVehicleReference {
        <<ValueObject>>
        -ExternalProvider provider
        -ExternalId external_id
        -DateTime~Utc~ linked_at
    }

    class VehicleSpecs {
        <<ValueObject>>
        -Brand brand
        -Model model
        -Option~Generation~ generation
        -Option~ManufactureYear~ manufacture_year
        -Option~BodyType~ body_type
        -Option~EngineSpec~ engine
        -Option~TransmissionSpec~ transmission
        -Option~Drivetrain~ drivetrain
        -Option~FuelType~ fuel_type
    }

    class VerificationInfo {
        <<ValueObject>>
        -VerificationSource source
        -ConfidenceLevel confidence
        -Option~ExternalVerificationRef~ ext_ref
        -DateTime~Utc~ verified_at
    }

    class VerificationSource {
        <<Enum>>
        ManualEntry
        TrustedRegistry
        ExternalApi
        DocumentScan
    }

    class ConfidenceLevel {
        <<Enum>>
        Low
        Medium
        High
    }

    class AggregateVersion {
        <<ValueObject>>
        -u64 value
        +initial() AggregateVersion
        +next() AggregateVersion
    }

    class PendingVehicleEvent {
        <<ValueObject>>
        -VehicleEvent payload
        -DateTime~Utc~ occurred_at
    }

    class VehicleEvent {
        <<DomainEventEnum>>
        VehicleCreatedV1
        VehicleVinAssignedV1
        VehicleVinCorrectedV1
        VehicleLicensePlateChangedV1
        VehicleRegistrationDocumentChangedV1
        VehicleExternalReferenceLinkedV1
        VehicleExternalReferenceUnlinkedV1
        VehicleSpecsUpdatedV1
        VehicleVerifiedV1
        VehicleStatusChangedV1
        VehicleDeletedV1
    }

    class VehicleError {
        <<DomainError>>
        NotInDraft
        AlreadyActive
        AlreadyDeleted
        VinAlreadyAssigned
        VinCorrectionUnauthorized
        NoReliableIdentityForActivation
        InvalidVin
        ExternalRefAlreadyLinked
        InvariantViolation
    }

    class VehicleInvariants {
        <<BusinessRules>>
        vehicle_id_is_immutable
        active_requires_reliable_identity
        vin_is_normalized_17_chars
        vin_correction_requires_privilege
        external_ref_unique_per_provider
        brand_and_model_required
        deleted_is_terminal
        no_change_emits_no_event
    }

    class VehicleActivationPermit {
        <<Capability>>
        -VehicleId vehicle_id
        -DateTime~Utc~ expires_at
        +is_valid_for(VehicleId, DateTime~Utc~) bool
    }

    class VehicleIdentityReservationProof {
        <<Capability>>
        -VehicleId vehicle_id
        -VehicleIdentityKey reserved_key
        -DateTime~Utc~ expires_at
        +is_valid_for(VehicleId) bool
    }

    Vehicle *-- "1" VehicleId : id
    Vehicle *-- "1" VehicleStatus : status
    Vehicle *-- "1" VehicleIdentity : identity
    Vehicle *-- "1" VehicleSpecs : specs
    Vehicle *-- "0..1" VerificationInfo : verification
    Vehicle *-- "1" AggregateVersion : version
    Vehicle *-- "0..*" PendingVehicleEvent : pending_events

    VehicleIdentity *-- "0..1" Vin
    VehicleIdentity *-- "0..1" LicensePlate
    VehicleIdentity *-- "0..1" RegistrationDocument
    VehicleIdentity *-- "0..*" ExternalVehicleReference

    VerificationInfo *-- "1" VerificationSource
    VerificationInfo *-- "1" ConfidenceLevel

    PendingVehicleEvent *-- "1" VehicleEvent

    Vehicle ..> VehicleError : raises
    Vehicle ..> VehicleInvariants : enforces
    Vehicle ..> VehicleActivationPermit : requires for activate
    Vehicle ..> VehicleIdentityReservationProof : requires for assign_vin / correct_vin

