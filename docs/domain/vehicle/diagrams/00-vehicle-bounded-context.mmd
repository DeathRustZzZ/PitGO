flowchart LR

    subgraph AuthLane["Authorization / Audit"]
        direction TB
        AccessContext["AccessContext"]
        ActionContextFactory["ActionContextFactory"]
        ActionCtx["ActionContext\nactor · roles · correlation"]
    end

    subgraph AppLane["Application Layer"]
        direction TB
        VehicleAppSvc["VehicleApplicationService"]
        OwnershipAppSvc["VehicleOwnershipApplicationService"]
        UnitOfWork["UnitOfWork\ntransaction + optimistic lock"]
        Repos["VehicleRepository\nVehicleOwnershipRepository"]
        OutboxVehicle["VehicleOutbox\nreliable event delivery"]
        EvtEnvFactory["EventEnvelopeFactory\npersistence boundary"]
    end

    subgraph PolicyLane["Policies / Capabilities"]
        direction TB
        ActPolicy["VehicleActivationPolicy"]
        ActPermit["VehicleActivationPermit\nrequired by Vehicle.activate()"]
        LifecyclePolicy["VehicleLifecyclePolicy\nblocks archive/delete with active ownership"]
        ConsistPolicy["OwnershipConsistencyPolicy\ncheck non-terminal ownerships"]
        EligSnap["OwnershipEligibilitySnapshot\nrequired by VehicleOwnership.start()"]
        ResvProof["VehicleIdentityReservationProof\nrequired by assign_vin / correct_vin"]
    end

    subgraph DomainLane["Aggregate Roots"]
        direction TB
        Vehicle["Vehicle\nidentity · specs · lifecycle"]
        VehicleOwnership["VehicleOwnership\noperational ownership"]
    end

    subgraph RegistryLane["Vehicle Identity Registry"]
        direction TB
        IdRegistry["VehicleIdentityRegistry\nreserve · claim · release VIN"]
        VinNorm["VinNormalizer"]
        IdKey["VehicleIdentityKey\nVIN / trusted external ref"]
    end

    subgraph EventLane["Eventing / Audit"]
        direction TB
        PendingVehEvt["PendingVehicleEvent\nraised inside Vehicle"]
        PendingOwnEvt["PendingOwnershipEvent\nraised inside VehicleOwnership"]
        VehEvents["VehicleEvent\n11 typed variants"]
        OwnEvents["VehicleOwnershipEvent\n6 typed variants"]
        EvtEnvelope["EventEnvelope\npersisted audit record"]
    end

    subgraph ExternalLane["External / ACL"]
        direction TB
        ExtAdapter["ExternalVehicleRegistryAdapter\nGIBDD · VIN API"]
    end

