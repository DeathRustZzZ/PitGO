%% Vehicle Domain Events — all typed event variants, EventEnvelopeFactory, EventEnvelope.
%% Source of truth: ARCHITECTURE.md § Vehicle Domain › Domain Events
%% Key difference from vehicle.md skeleton: every event carries a full typed payload (not just vehicle_id).
%% Mirrors: docs/domain/customer/diagrams/06-eventing-audit.mmd

classDiagram
    direction LR

    %% ── Vehicle events ────────────────────────────────────────────────────────

    class PendingVehicleEvent {
        <<ValueObject>>
        -VehicleEvent payload
        -DateTime~Utc~ occurred_at
    }

    class VehicleEvent {
        <<DomainEventEnum>>
        VehicleCreatedV1
        VehicleVinAssignedV1
        VehicleVinCorrectedV1
        VehicleLicensePlateChangedV1
        VehicleRegistrationDocumentChangedV1
        VehicleExternalReferenceLinkedV1
        VehicleExternalReferenceUnlinkedV1
        VehicleSpecsUpdatedV1
        VehicleVerifiedV1
        VehicleStatusChangedV1
        VehicleDeletedV1
    }

    class VehicleCreatedV1 {
        <<EventPayload>>
        +VehicleId vehicle_id
        +VehicleSpecsSnapshot specs_snapshot
        +VehicleIdentitySnapshot identity_snapshot
        +ActorId created_by
        +DateTime~Utc~ occurred_at
    }

    class VehicleVinAssignedV1 {
        <<EventPayload>>
        +VehicleId vehicle_id
        +Vin vin
        +ReservationId reservation_id
        +ActorId assigned_by
        +DateTime~Utc~ occurred_at
    }

    class VehicleVinCorrectedV1 {
        <<EventPayload>>
        +VehicleId vehicle_id
        +Option~Vin~ previous_vin
        +Vin new_vin
        +VinCorrectionReason correction_reason
        +ActorId corrected_by
        +DateTime~Utc~ occurred_at
    }

    class VehicleStatusChangedV1 {
        <<EventPayload>>
        +VehicleId vehicle_id
        +VehicleStatus previous_status
        +VehicleStatus new_status
        +Option~String~ reason
        +ActorId actor
        +DateTime~Utc~ occurred_at
    }

    class VehicleVerifiedV1 {
        <<EventPayload>>
        +VehicleId vehicle_id
        +VerificationSource source
        +ConfidenceLevel confidence
        +Option~ExternalVerificationRef~ ext_ref
        +ActorId verified_by
        +DateTime~Utc~ occurred_at
    }

    class VehicleDeletedV1 {
        <<EventPayload>>
        +VehicleId vehicle_id
        +ActorId deleted_by
        +DateTime~Utc~ occurred_at
    }

    %% ── VehicleOwnership events ───────────────────────────────────────────────

    class PendingOwnershipEvent {
        <<ValueObject>>
        -VehicleOwnershipEvent payload
        -DateTime~Utc~ occurred_at
    }

    class VehicleOwnershipEvent {
        <<DomainEventEnum>>
        VehicleOwnershipStartedV1
        VehicleOwnershipVerifiedV1
        VehicleOwnershipRejectedV1
        VehicleOwnershipDisputedV1
        VehicleOwnershipResolvedV1
        VehicleOwnershipEndedV1
    }

    class VehicleOwnershipStartedV1 {
        <<EventPayload>>
        +VehicleOwnershipId ownership_id
        +VehicleId vehicle_id
        +CustomerId owner_customer_id
        +OwnershipType ownership_type
        +ActorId registered_by
        +DateTime~Utc~ started_at
    }

    class VehicleOwnershipEndedV1 {
        <<EventPayload>>
        +VehicleOwnershipId ownership_id
        +VehicleId vehicle_id
        +Option~String~ reason
        +ActorId ended_by
        +DateTime~Utc~ ended_at
    }

    class VehicleOwnershipResolvedV1 {
        <<EventPayload>>
        +VehicleOwnershipId ownership_id
        +VehicleId vehicle_id
        +String resolution
        +ActorId resolved_by
        +DateTime~Utc~ occurred_at
    }

    %% ── Envelope infrastructure ───────────────────────────────────────────────

    class EventEnvelopeFactory {
        <<DomainService>>
        +wrap(Vec~PendingVehicleEvent~, ActionContext) Vec~EventEnvelope~
        +wrap_ownership(Vec~PendingOwnershipEvent~, ActionContext) Vec~EventEnvelope~
    }

    class EventEnvelope {
        <<AuditRecord>>
        -EventId event_id
        -AggregateType aggregate_type
        -AggregateId aggregate_id
        -AggregateVersion version
        -String event_type
        -JsonB payload
        -CorrelationId correlation_id
        -CausationId causation_id
        -ActorId actor_id
        -DateTime~Utc~ occurred_at
        -DateTime~Utc~ stored_at
    }

    class ActionContext {
        <<ExternalRef>>
        -ActorId actor_id
        -Vec~RoleSnapshot~ role_snapshots
        -CorrelationId correlation_id
        -CausationId causation_id
    }

    PendingVehicleEvent *-- "1" VehicleEvent : payload
    VehicleEvent *-- VehicleCreatedV1 : variant
    VehicleEvent *-- VehicleVinAssignedV1 : variant
    VehicleEvent *-- VehicleVinCorrectedV1 : variant
    VehicleEvent *-- VehicleStatusChangedV1 : variant
    VehicleEvent *-- VehicleVerifiedV1 : variant
    VehicleEvent *-- VehicleDeletedV1 : variant

    PendingOwnershipEvent *-- "1" VehicleOwnershipEvent : payload
    VehicleOwnershipEvent *-- VehicleOwnershipStartedV1 : variant
    VehicleOwnershipEvent *-- VehicleOwnershipEndedV1 : variant
    VehicleOwnershipEvent *-- VehicleOwnershipResolvedV1 : variant

    EventEnvelopeFactory ..> PendingVehicleEvent : consumes
    EventEnvelopeFactory ..> PendingOwnershipEvent : consumes
    EventEnvelopeFactory ..> ActionContext : uses for metadata
    EventEnvelopeFactory ..> EventEnvelope : produces

    style PendingVehicleEvent fill:#FEF9C3,stroke:#CA8A04,color:#0F172A
    style VehicleEvent fill:#FEF9C3,stroke:#CA8A04,color:#0F172A
    style VehicleCreatedV1 fill:#FEF9C3,stroke:#CA8A04,color:#0F172A
    style VehicleVinAssignedV1 fill:#FEF9C3,stroke:#CA8A04,color:#0F172A
    style VehicleVinCorrectedV1 fill:#FEF9C3,stroke:#CA8A04,color:#0F172A
    style VehicleStatusChangedV1 fill:#FEF9C3,stroke:#CA8A04,color:#0F172A
    style VehicleVerifiedV1 fill:#FEF9C3,stroke:#CA8A04,color:#0F172A
    style VehicleDeletedV1 fill:#FEF9C3,stroke:#CA8A04,color:#0F172A
    style PendingOwnershipEvent fill:#FEF9C3,stroke:#CA8A04,color:#0F172A
    style VehicleOwnershipEvent fill:#FEF9C3,stroke:#CA8A04,color:#0F172A
    style VehicleOwnershipStartedV1 fill:#FEF9C3,stroke:#CA8A04,color:#0F172A
    style VehicleOwnershipEndedV1 fill:#FEF9C3,stroke:#CA8A04,color:#0F172A
    style VehicleOwnershipResolvedV1 fill:#FEF9C3,stroke:#CA8A04,color:#0F172A
    style EventEnvelopeFactory fill:#FFEDD5,stroke:#EA580C,color:#0F172A
    style EventEnvelope fill:#FEF9C3,stroke:#CA8A04,color:#0F172A
    style ActionContext fill:#F1F5F9,stroke:#64748B,stroke-dasharray:5 5,color:#0F172A
