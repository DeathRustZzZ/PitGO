%% Ownership Transfer Flow — end current ownership, start new one in a single transaction.
%% Source of truth: ARCHITECTURE.md § Vehicle Domain › VehicleLifecyclePolicy, VehicleOwnershipApplicationService
%% Key constraint: only one Active ownership per vehicle at any time.
%% Enforced by: OwnershipConsistencyPolicy (app layer) + DB partial index (safety net).

flowchart TD

    Start(["TransferOwnershipCommand\nvehicle_id · new_owner_id · ownership_type · ctx"])
    LoadVehicle["VehicleRepository\nfind_by_id(vehicle_id)"]
    LifecycleCheck["VehicleLifecyclePolicy\ncheck_vehicle_eligible_for_ownership(vehicle)"]
    NoteLifecycle["Blocks if vehicle.status\nin [Deleted, Archived]"]
    VehicleEligible{vehicle\neligible?}
    ReturnNotEligible(["Err: VehicleNotEligibleForOwnership"])

    FindActive["VehicleOwnershipRepository\nfind_active_for_vehicle(vehicle_id)"]
    BuildSnapshot["OwnershipConsistencyPolicy\nbuild_eligibility_snapshot(active_ownership)"]

    HasActive{active\nownership\nexists?}
    EndCurrent["VehicleOwnership (current)\nend(reason=Transfer · ctx · now)\nActive → Ended (terminal)\nEmits: VehicleOwnershipEndedV1"]

    StartNew["VehicleOwnership (new)\nstart(id · vehicle_id · new_owner_id · type · snapshot · ctx · now)\nstatus: PendingVerification\nEmits: VehicleOwnershipStartedV1"]
    NoteStart["Guard: snapshot.no_active_ownership_exists() == true"]

    BeginTx["UnitOfWork.begin()"]
    SaveCurrent["VehicleOwnershipRepository\nsave(current ownership)"]
    SaveNew["VehicleOwnershipRepository\nsave(new ownership)"]
    NoteIndex["DB partial index on (vehicle_id, status=Active)\nenforces non-terminal rule as safety net"]
    PullEvents["pull_pending_events()\nfrom current + new ownership"]
    WrapEnvelopes["EventEnvelopeFactory.wrap\nall events · ctx → Vec~EventEnvelope~"]
    Enqueue["VehicleOutbox.enqueue(envelopes)"]
    Commit["UnitOfWork.commit()"]
    OK(["Ok(())"])

    Start --> LoadVehicle
    LoadVehicle --> LifecycleCheck
    LifecycleCheck --> NoteLifecycle
    NoteLifecycle --> VehicleEligible
    VehicleEligible -- No --> ReturnNotEligible
    VehicleEligible -- Yes --> FindActive
    FindActive --> BuildSnapshot
    BuildSnapshot --> HasActive
    HasActive -- Yes --> EndCurrent
    EndCurrent --> StartNew
    HasActive -- No --> StartNew
    StartNew --> NoteStart
    NoteStart --> BeginTx
    BeginTx --> SaveCurrent
    SaveCurrent --> SaveNew
    SaveNew --> NoteIndex
    NoteIndex --> PullEvents
    PullEvents --> WrapEnvelopes
    WrapEnvelopes --> Enqueue
    Enqueue --> Commit
    Commit --> OK

