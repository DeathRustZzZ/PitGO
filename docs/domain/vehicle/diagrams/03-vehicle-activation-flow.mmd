    style NoteIdentity fill:#FFEDD5,stroke:#EA580C,color:#0F172A
    style NoteGuards fill:#FFEDD5,stroke:#EA580C,color:#0F172A
    style IssuePermit fill:#DCFCE7,stroke:#16A34A,stroke-dasharray:5 5,color:#0F172A
    style CallActivate fill:#1D4ED8,stroke:#1E3A8A,stroke-width:3px,color:#FFFFFF
    style EmitEvent fill:#FEF9C3,stroke:#CA8A04,color:#0F172A
    style ReturnDenied fill:#FEE2E2,stroke:#DC2626,color:#0F172A
    style ReturnVehicleErr fill:#FEE2E2,stroke:#DC2626,color:#0F172A
    style OK fill:#DCFCE7,stroke:#16A34A,color:#0F172A
