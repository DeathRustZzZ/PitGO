%% Vehicle Activation Flow — VehicleActivationPolicy issues a permit; Vehicle.activate() accepts only the permit.
%% Source of truth: ARCHITECTURE.md § Vehicle Domain › VehicleActivationPolicy
%% Mirrors: docs/domain/customer/diagrams/07-activation-flow.mmd (ActivationPermit pattern)

flowchart TD

    Start(["ActivateVehicleCommand\nvehicle_id · ctx"])
    LoadVehicle["VehicleRepository\nfind_by_id(vehicle_id)"]
    CheckPolicy["VehicleActivationPolicy\ncheck_eligibility(vehicle)"]
    ReliableId{has_reliable\nidentity?}
    NoteIdentity["Reliable identity =\nVIN alone (verified), OR\ntrusted external ref + license_plate"]
    ReturnDenied(["Err: NoReliableIdentityForActivation"])
    IssuePermit["Issue VehicleActivationPermit\nvehicle_id · expires_at"]
    CallActivate["Vehicle.activate\npermit · ctx · now"]
    StatusDraft{status\n== Draft?}
    NoteGuards["Guards inside aggregate:\n• permit.is_valid_for(self.id, now)\n• self.status == Draft"]
    ReturnVehicleErr(["Err: VehicleError\n(AlreadyActive / Archived / Deleted)"])
    EmitEvent["Emit PendingVehicleEvent\nVehicleStatusChangedV1\nDraft → Active"]
    BeginTx["UnitOfWork.begin()"]
    SaveVehicle["VehicleRepository.save(vehicle)\ncompare-and-set AggregateVersion"]
    PullEvents["Vehicle.pull_pending_events()"]
    WrapEnvelopes["EventEnvelopeFactory.wrap\nevents · ctx → Vec~EventEnvelope~"]
    Enqueue["VehicleOutbox.enqueue(envelopes)"]
    Commit["UnitOfWork.commit()"]
    OK(["Ok(())"])

    Start --> LoadVehicle
    LoadVehicle --> CheckPolicy
    CheckPolicy --> NoteIdentity
    NoteIdentity --> ReliableId
    ReliableId -- No --> ReturnDenied
    ReliableId -- Yes --> IssuePermit
    IssuePermit --> CallActivate
    CallActivate --> NoteGuards
    NoteGuards --> StatusDraft
    StatusDraft -- No --> ReturnVehicleErr
    StatusDraft -- Yes --> EmitEvent
    EmitEvent --> BeginTx
    BeginTx --> SaveVehicle
    SaveVehicle --> PullEvents
    PullEvents --> WrapEnvelopes
    WrapEnvelopes --> Enqueue
    Enqueue --> Commit
    Commit --> OK

