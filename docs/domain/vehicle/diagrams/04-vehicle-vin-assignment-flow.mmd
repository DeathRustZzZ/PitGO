%% VIN Assignment Flow — TOCTOU-safe uniqueness via VehicleIdentityReservationProof.
%% Source of truth: ARCHITECTURE.md § Vehicle Domain › VehicleIdentityRegistry
%% VIN scope: global (unique across all tenants and vehicles).
%% Mirrors: IdentityReservationProof pattern from Customer domain.

flowchart TD

    Start(["AssignVinCommand\nvehicle_id · raw_vin · ctx"])
    Normalize["VinNormalizer\nnormalize(raw_vin)"]
    ValidVin{valid\nformat?}
    ReturnInvalid(["Err: InvalidVin"])

    Reserve["VehicleIdentityRegistry\nreserve(VehicleIdentityKey::Vin, vehicle_id)"]
    NoteReserve["Atomic check-and-insert.\nScope: global — VIN unique across all tenants.\nReservation is short-lived (TTL)."]
    VinFree{VIN\nfree?}
    ReturnClaimed(["Err: VinAlreadyTaken\n(IdentityAlreadyClaimed)"])

    LoadVehicle["VehicleRepository\nfind_by_id(vehicle_id)"]
    CallAssign["Vehicle.assign_vin\nproof · vin · ctx · now"]
    NoteGuards["Guards inside aggregate:\n• proof.is_valid_for(self.id)\n• self.identity.vin.is_none()\n• self.status != Deleted"]
    VinAssignable{preconditions\nmet?}

    Release["VehicleIdentityRegistry\nrelease(proof)\nrollback reservation — no leak"]
    ReturnVehicleErr(["Err: VehicleError"])

    EmitEvent["Emit PendingVehicleEvent\nVehicleVinAssignedV1"]
    BeginTx["UnitOfWork.begin()"]
    SaveVehicle["VehicleRepository.save(vehicle)\ncompare-and-set AggregateVersion"]
    Claim["VehicleIdentityRegistry\nclaim(proof)\nreservation → permanent claim"]
    NoteClaim["Both save + claim in same transaction.\nIf commit fails → both rollback atomically."]
    PullEvents["Vehicle.pull_pending_events()"]
    WrapEnvelopes["EventEnvelopeFactory.wrap\nevents · ctx → Vec~EventEnvelope~"]
    Enqueue["VehicleOutbox.enqueue(envelopes)"]
    Commit["UnitOfWork.commit()"]
    OK(["Ok(())"])

    Start --> Normalize
    Normalize --> ValidVin
    ValidVin -- No --> ReturnInvalid
    ValidVin -- Yes --> Reserve
    Reserve --> NoteReserve
    NoteReserve --> VinFree
    VinFree -- No --> ReturnClaimed
    VinFree -- Yes --> LoadVehicle
    LoadVehicle --> CallAssign
    CallAssign --> NoteGuards
    NoteGuards --> VinAssignable
    VinAssignable -- No --> Release
    Release --> ReturnVehicleErr
    VinAssignable -- Yes --> EmitEvent
    EmitEvent --> BeginTx
    BeginTx --> SaveVehicle
    SaveVehicle --> Claim
    Claim --> NoteClaim
    NoteClaim --> PullEvents
    PullEvents --> WrapEnvelopes
    WrapEnvelopes --> Enqueue
    Enqueue --> Commit
    Commit --> OK

